# Copy to backend/.env when using Docker infrastructure (docker-compose.dev.yml)
# Postgres is on host port 5433

DATABASE_URL=postgresql+asyncpg://nexusai:nexusai_dev@localhost:5433/nexusai
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8001

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
LLM_PROVIDER=ollama

SANDBOX_USE_DOCKER=true
SANDBOX_PREWARM_ON_STARTUP=true
RAG_RERANK_ENABLED=true
