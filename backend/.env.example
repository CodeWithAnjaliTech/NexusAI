# NexusAI Backend — copy to .env and adjust for your setup
#
# TWO MODES:
#   Local (no Docker infra):  cp .env.local .env   → Postgres on :5432
#   Docker infra:             cp .env.docker .env   → Postgres on :5433
#
# See scripts/setup-local.sh or scripts/setup-docker.sh

APP_NAME=NexusAI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Database — pick ONE:
# Local Homebrew Postgres:
DATABASE_URL=postgresql+asyncpg://nexusai:nexusai_dev@localhost:5432/nexusai
# Docker Postgres (after docker compose -f docker-compose.dev.yml up -d):
# DATABASE_URL=postgresql+asyncpg://nexusai:nexusai_dev@localhost:5433/nexusai

REDIS_URL=redis://localhost:6379/0

CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=nexusai_knowledge

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

LLM_PROVIDER=ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Optional for scanned PDF OCR (also install system tesseract: brew install tesseract)
# pymupdf is in requirements.txt; pytesseract + tesseract required for OCR
RAG_TOP_K=5
RAG_FETCH_K=15

SANDBOX_USE_DOCKER=true
SANDBOX_IMAGE=python:3.12-alpine
SANDBOX_TIMEOUT_SECONDS=45
SANDBOX_MEMORY_LIMIT=128m
SANDBOX_CPU_LIMIT=0.5
SANDBOX_MAX_CODE_CHARS=8000
SANDBOX_MAX_CONCURRENT=5
SANDBOX_PREWARM_ON_STARTUP=true
SANDBOX_WARM_CONTAINERS=true
SANDBOX_DOCKER_CHECK_SECONDS=3
SANDBOX_PULL_TIMEOUT_SECONDS=30
SANDBOX_CONTAINER_START_SECONDS=20

SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_WINDOW_SECONDS=60

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
